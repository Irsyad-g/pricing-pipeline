{
  "_meta": {
    "version": "2.0",
    "description": "Single source of truth for country mapping, regions, and group labels",
    "region_hierarchy": {
      "ASIA": ["ASIA_EAST", "ASIA_SEA"],
      "EUROPE": ["EUROPE"],
      "MIDDLE_EAST": ["MIDDLE_EAST"],
      "AMERICA": ["AMERICA"],
      "OCEANIA": ["OCEANIA"]
    },
    "fields": {
      "patterns": "List of package name substrings for matching (UPPERCASE)",
      "group": "Display label used in reports and Excel sheets",
      "region": "Granular region for BF fallback scoring",
      "region_group": "Coarse region for report splitting (ASIA, EUROPE, etc)",
      "regions": "Optional — list of granular regions this code contributes BF data to (multi-country products only)",
      "force_include": "Always generate full SKU matrix even without sales data"
    }
  },

  "CHMPLUS": {
    "patterns": [
      "CHINA HONGKONG MACAU + TRANSIT",
      "CHINA HONGKONG MACAU",
      "CHINA HONG KONG MACAU",
      "CHINA, HONG KONG, MACAU",
      "ESIM CHINA",
      "ESIM CHINA HONG KONG MACAU",
      "ESIM CHINA, HONG KONG, MACAU"
    ],
    "group": "China Hongkong Macau + Transit",
    "region": "ASIA_EAST",
    "region_group": "ASIA",
    "force_include": true
  },
  "CHMMAX": {
    "patterns": [
      "CHINA HONGKONG MACAU + TRANSIT DATAMAX",
      "CHINA + TRANSIT DATAMAX"
    ],
    "group": "China Hongkong Macau + Transit DataMax",
    "region": "ASIA_EAST",
    "region_group": "ASIA",
    "force_include": true
  },

  "JPNPLUS": {
    "patterns": [
      "JAPAN + TRANSIT",
