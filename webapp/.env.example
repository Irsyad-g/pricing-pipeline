# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=postgres
DB_PASSWORD=your_password

# DB schema / table names (change if yours differ)
SCHEMA_PROCESSED=processed
SCHEMA_RAW=raw
TABLE_FINAL=final_output
TABLE_COUNTRY=country_usage
TABLE_SUB=subscription

# Web server (optional — defaults work for LAN)
APP_HOST=0.0.0.0
APP_PORT=5000
